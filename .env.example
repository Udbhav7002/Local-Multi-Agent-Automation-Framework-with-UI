# Model Configurations
MANAGER_MODEL=llama3:8b-instruct-q8_0
WORKER_MODEL=llama3:8b-instruct-q8_0
VISION_MODEL=llava:13b
OLLAMA_BASE_URL=http://localhost:11434

# Context & Timeouts
NUM_CTX=8192
CLI_TIMEOUT=60.0
CLI_MAX_OUTPUT=2000
LLM_TIMEOUT=120.0

# Plan Execution
MAX_PLAN_REGENERATIONS=3
MAX_STEP_RETRIES=2

# System Context (Optional: Override auto-detection)
# OS_CONTEXT="macOS"

# Memory Thresholds (Cosine Distance)
MEMORY_SUCCESS_THRESHOLD=0.15
MEMORY_FAILURE_THRESHOLD=0.20
MEMORY_EPISODE_THRESHOLD=0.25

# Logging
DEBUG=False
ENABLE_JSON_LOGGING=True
